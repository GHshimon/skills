{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "ghshimon-skills": {
      "source": { "source": "github", "repo": "GHshimon/skills" }
    }
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true,
    "ai-company-skills@ghshimon-skills": true
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/id_rsa*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(rm -rf:*)",
      "Bash(git branch -D:*)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh repo delete:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/skill-foundry/scripts/validate_hook.py\"",
            "timeout": 30,
            "statusMessage": "SKILL.md を検証中..."
          }
        ]
      }
    ]
  }
}
