{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/skill-foundry/scripts/validate_hook.py\"",
            "timeout": 30,
            "statusMessage": "SKILL.md を検証中..."
          }
        ]
      }
    ]
  }
}
